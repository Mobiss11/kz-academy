# Скопируй этот файл в .env и пропиши свои ключи.
# .env уже в .gitignore — он НЕ попадёт в репозиторий.
#
# 📖 Полный гайд по регистрации каждого сервиса: docs/full-stack-setup.md
# 📖 Только RapidAPI (минимум для старта): docs/getting-started.md
#
# ВАЖНО: Закомментируй переменные тех сервисов, которые ТЫ НЕ ИСПОЛЬЗУЕШЬ.
# Установи только то, что реально нужно для твоего pipeline.

# ============================================================
# 1. RAPIDAPI — обязательно для всех коннекторов
# ============================================================
# Где взять: https://rapidapi.com/developer/security
# Один ключ работает со всеми API, но для каждого нужна
# отдельная подписка (Basic free доступен для всех).
RAPIDAPI_KEY=your-rapidapi-key-here

# ============================================================
# 2. OPENROUTER — универсальный LLM (Claude/GPT/Gemini/DeepSeek/...)
# ============================================================
# Где взять: https://openrouter.ai/settings/keys
# Минимальный депозит: $5
# Документация моделей: docs/methodology/llm-models.md
# OPENROUTER_API_KEY=sk-or-v1-...

# ============================================================
# 3. ТРАНСКРИПЦИЯ — выбери ОДИН сервис
# ============================================================

# Вариант A: OpenAI Whisper API ($0.006/мин, универсал)
# Где: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Вариант B: Replicate Whisper Large v3 ($0.0008/мин, в 7× дешевле!)
# Где: https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=r8_...

# Вариант C: Deepgram Nova-2 ($0.0043/мин, топ скорость)
# Где: https://console.deepgram.com (на старте $200 бесплатно)
# DEEPGRAM_API_KEY=...

# Вариант D: Yandex SpeechKit (от ₽0.10/сек, топ для RU)
# Где: https://console.cloud.yandex.ru
# YANDEX_API_KEY=...
# YANDEX_FOLDER_ID=...

# ============================================================
# 4. S3 STORAGE — выбери ОДИН провайдер
# ============================================================

# Вариант A: AWS S3 ($0.023/GB + egress fees)
# Где: https://aws.amazon.com → IAM → Users → Access keys
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# S3_BUCKET=my-content-factory

# Вариант B: Cloudflare R2 ($0.015/GB, $0 egress!) — рекомендуется
# Где: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET=my-content-factory
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Вариант C: Yandex Object Storage (для RU, ₽1.85/GB)
# YC_ACCESS_KEY=...
# YC_SECRET_KEY=...
# YC_BUCKET=my-content-factory
# YC_ENDPOINT=https://storage.yandexcloud.net

# ============================================================
# 5. TELEGRAM BOT — для уведомлений (бесплатно)
# ============================================================
# Где взять: напиши @BotFather в Telegram → /newbot
# TELEGRAM_BOT_TOKEN=1234567890:ABCdef...

# ============================================================
# 6. БД И КЭШ
# ============================================================
# PostgreSQL (локально через Docker или managed Supabase/Neon/Railway)
# DATABASE_URL=postgresql://postgres:changeme@localhost:5432/content_factory

# Redis (локально через Docker или managed Upstash)
# REDIS_URL=redis://localhost:6379/0
